# MII_lite environment configuration
#
# All values below are examples or demo defaults.
# The application runs without any .env file — demo authentication is
# disabled by default, and all domain logic works out of the box.
#
# To use: copy this file to .env.local and adjust values as needed.
# Do not commit .env.local or any file containing real secrets.

# ---------------------------------------------------------------------------
# Demo authentication gate
# ---------------------------------------------------------------------------
# These control a lightweight demo-access gate (shared access code + cookie).
# This is NOT production authentication or authorization.
# When disabled (the default), all routes are accessible without login.

DEMO_AUTH_ENABLED=false
NEXT_PUBLIC_DEMO_AUTH_ENABLED=false

# Cookie name used for the demo session (optional, has a safe default)
DEMO_COOKIE_NAME=mii_demo_access

# Session token value — replace with a random string if enabling demo auth
DEMO_SESSION_TOKEN=replace-with-random-demo-token

# Access code a visitor enters to gain demo access
DEMO_ACCESS_CODE=replace-with-demo-access-code
